{
  "manifest_version": 3,
  "name": "Scanline - Amazon Review Analyzer",
  "version": "1.0.0",
  "description": "Scans and analyzes product reviews for organic authenticity using local heuristic rules.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.in/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.ca/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "scanline@utkarshvashishtha.com"
    }
  }
}
